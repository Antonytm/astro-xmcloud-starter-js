---
import { ComponentProps } from "@/lib/component-props";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";
import { TextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import NavigationList from "components/NestedComponents/NavigationList.astro";

export interface Fields {
  Id: string;
  DisplayName: string;
  Title: TextField;
  NavigationTitle: TextField;
  Href: string;
  Querystring: string;
  Children: Array<Fields>;
  Styles: string[];
}

interface NavigationProps extends ComponentProps {
  fields: Fields;
}

const { params, fields } = Astro.props as NavigationProps;
const { page } = useSitecore();
const { styles, RenderingIdentifier: id } = params;

const isEmpty = !Object.values(fields).length;
---

<>{
    isEmpty && (
      <div class={`component navigation ${styles}`} id={id}>
        <div class="component-content">[Navigation]</div>
      </div>
    )
  }
  {
    !isEmpty && (
      <div class={`component navigation ${styles}`} id={id}>
        <label class="menu-mobile-navigate-wrapper">
          <input
            type="checkbox"
            class="menu-mobile-navigate"
            data-isPageEditing={page.mode.isEditing}
          />
          {/* DEMO TEAM CUSTOMIZATION */}
          <div class="menu-humburger">
            <span />
            <span />
            <span />
          </div>
          <div class="component-content">
            <nav>
              {/* DEMO TEAM CUSTOMIZATION */}
              <ul>
                {Object.values(fields)
                  .filter((element) => element)
                  .map((element: Fields, key: number) => (
                    <NavigationList fields={element} relativeLevel={1} />
                  ))}
              </ul>
            </nav>
          </div>
        </label>
      </div>
    )
  }
</>

<script>
  import { handleToggleMenu } from "components/scripts/Menu";

  const menuMobileNavigate = document.getElementsByClassName(
    "menu-mobile-navigate"
  )[0];
  menuMobileNavigate?.addEventListener("change", (event) => {
    handleToggleMenu(event);
  });
</script>
