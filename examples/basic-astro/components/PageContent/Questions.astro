---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import QuestionsDefault from "components/Variants/QuestionsVariants/QuestionsDefault.astro";
import QuestionsSingleColumn from "components/Variants/QuestionsVariants/QuestionsSingleColumn.astro";

interface QuestionFields {
  Question: Field<string>;
  Answer: Field<string>;
}

export interface QuestionItemProps {
  fields: QuestionFields;
}

export interface QuestionsProps extends ComponentProps {
  fields: {
    items: QuestionItemProps[];
  };
}

const props = Astro.props as QuestionsProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <QuestionsDefault {...props} />}
  {variantName === "SingleColumn" && <QuestionsSingleColumn {...props} />}
</>
