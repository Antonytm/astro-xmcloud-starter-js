---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Link from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import Placeholder from "@astro-sitecore-jss/astro-content-sdk/src/components/Placeholder.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";
import { ComponentProps } from "@/lib/component-props";
import IconAccent from "components/NonSitecore/IconAccent.astro";
import DottedAccent from "components/NonSitecore/DottedAccent.astro";

interface Fields {
  Tagline: Field<string>;
  Title: Field<string>;
  Text: RichTextField;
  Image: ImageField;
  Cta1: LinkField;
  Cta2: LinkField;
  Icon: ImageField;
}

export interface HeroBannerProps extends ComponentProps {
  fields: Fields;
}

const { params, fields, rendering } = Astro.props as HeroBannerProps;
const { styles, RenderingIdentifier: id } = params;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
---

<div class={`component hero-banner ${styles?.trimEnd()}`} id={id}>
  <div class="container container-wide">
    <div class="hero-row">
      <div class="content-column">
        <h6 class="eyebrow-accent">
          <Text field={fields.Tagline} class="hello" />
        </h6>
        <h1 class="display-2 fw-bold">
          <Text field={fields.Title} />
        </h1>

        <div class="rich-content mb-4">
          <RichText field={fields.Text} />
        </div>
        <div class="btn-array pt-3 pb-4">
          {
            (isPageEditing || fields.Cta1?.value?.href) && (
              <Link field={fields.Cta1} class="button button-main" />
            )
          }{
            (isPageEditing || fields.Cta2?.value?.href) && (
              <Link field={fields.Cta2} class="button button-simple mx-4" />
            )
          }
        </div>
        <div class="row mt-2">
          <Placeholder name="hero-banner" rendering={rendering} />
        </div>
        <IconAccent image={fields.Icon} />
      </div>
      <div class="img-column">
        <div class="img-wrapper">
          <DottedAccent class="dotted-accent-top" />
          <AstroImage field={fields.Image} class="img-fluid" />
          <DottedAccent class="dotted-accent-bottom" />
        </div>
      </div>
    </div>
  </div>
</div>
