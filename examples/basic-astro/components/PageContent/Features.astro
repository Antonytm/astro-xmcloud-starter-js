---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import Link, {
  LinkField,
} from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import RichText, {
  RichTextField,
} from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";

import { ComponentProps } from "@/lib/component-props";

interface Fields {
  Eyebrow: Field<string>;
  Text: RichTextField;
  Link: LinkField;
  Image1: ImageField;
  Title1: Field<string>;
  Text1: Field<string>;
  Title2: Field<string>;
  Text2: Field<string>;
}

export interface FeaturesProps extends ComponentProps {
  fields: Fields;
}

const { params, fields } = Astro.props as FeaturesProps;
const { styles, RenderingIdentifier: id } = params;
---

<div class={`component features component-spaced ${styles?.trimEnd()}`} id={id}>
  <div class="container">
    <div class="info">
      <div class="eyebrow-accent">
        <Text field={fields.Eyebrow} />
      </div>
      <div class="tagline">
        <RichText field={fields.Text} />
      </div>
      <div class="button button-main">
        <Link field={fields.Link} />
      </div>
    </div>
    <div class="items">
      <div class="item left">
        <div class="icon">
          <AstroImage field={fields.Image1} />
        </div>
        <div class="title">
          <Text field={fields.Title1} />
        </div>
        <p class="subtitle">
          <Text field={fields.Text1} />
        </p>
      </div>
      <div class="item right">
        <div class="title">
          <Text field={fields.Title2} />
        </div>
        <p class="subtitle">
          <Text field={fields.Text2} />
        </p>
      </div>
    </div>
  </div>
</div>
