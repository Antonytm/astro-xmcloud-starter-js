---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import AuthorDetailsSimple from "components/Variants/AuthorDetailsVariants/AuthorDetailsSimple.astro";
import AuthorDetailsDefault from "components/Variants/AuthorDetailsVariants/AuthorDetailsDefault.astro";

interface Fields {
  Name: Field<string>;
  Position: Field<string>;
  Photo: ImageField;
  Bio: RichTextField;
  BackgroundImage: ImageField;
}

export interface AuthorDetailsProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as AuthorDetailsProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <AuthorDetailsDefault {...props} />}
  {variantName === "Simple" && <AuthorDetailsSimple {...props} />}
</>
