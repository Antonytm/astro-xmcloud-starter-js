---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { ComponentProps } from "@/lib/component-props";
import DocumentItem from "components/NestedComponents/DocumentItem.astro";

interface Fields {
  Title1: Field<string>;
  Subtitle1: Field<string>;
  Image1: ImageField;
  Link1: LinkField;
  Subtitle2: Field<string>;
  Image2: ImageField;
  Link2: LinkField;
  Subtitle3: Field<string>;
  Image3: ImageField;
  Link3: LinkField;
  Subtitle4: Field<string>;
  Image4: ImageField;
  Link4: LinkField;
}

export interface DocumentsListProps extends ComponentProps {
  fields: Fields;
}

const { fields, params } = Astro.props as DocumentsListProps;
const { styles, RenderingIdentifier: id } = params;
---

<div
  class={`component component-spaced documents-list ${styles?.trimEnd()}`}
  id={id}
>
  <div class="container">
    <div class="title display-6">
      <Text field={fields?.Title1} />
    </div>
    <div class="documents-container">
      <div class="row row-cols-1 row-cols-xl-2 gx-4 justify-content-center">
        <DocumentItem
          image={fields?.Image1}
          subtitle={fields?.Subtitle1}
          link={fields?.Link1}
          delay={0}
        />
        <DocumentItem
          image={fields?.Image2}
          subtitle={fields?.Subtitle2}
          link={fields?.Link2}
          delay={500}
        />
        <DocumentItem
          image={fields?.Image3}
          subtitle={fields?.Subtitle3}
          link={fields?.Link3}
          delay={1000}
        />
        <DocumentItem
          image={fields?.Image4}
          subtitle={fields?.Subtitle4}
          link={fields?.Link4}
          delay={1500}
        />
      </div>
    </div>
  </div>
</div>
