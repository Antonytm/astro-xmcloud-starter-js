---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";

import AuthorWidgetDefault from "components/Variants/AuthorWidgetVariants/AuthorWidgetDefault.astro";
import AuthorWidgetWithSocials from "components/Variants/AuthorWidgetVariants/AuthorWidgetWithSocials.astro";

interface Fields {
  Name: Field<string>;
  Position: Field<string>;
  Photo: ImageField;
  SocialLink1: LinkField;
  SocialIcon1: ImageField;
  SocialLink2: LinkField;
  SocialIcon2: ImageField;
  SocialLink3: LinkField;
  SocialIcon3: ImageField;
}

export interface AuthorWidgetProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as AuthorWidgetProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <AuthorWidgetDefault {...props} />}
  {variantName === "WithSocials" && <AuthorWidgetWithSocials {...props} />}
</>
