---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import ArticleListDefault from "components/Variants/ArticleListVariants/ArticleListDefault.astro";
import ArticleListThreeColumn from "components/Variants/ArticleListVariants/ArticleListThreeColumn.astro";
import ArticleListSimplified from "components/Variants/ArticleListVariants/ArticleListSimplified.astro";
import ArticleListGrid from "components/Variants/ArticleListVariants/ArticleListGrid.astro";

interface Fields {
  Title: Field<string>;
  Excerpt: Field<string>;
  Content: RichTextField;
  Thumbnail: ImageField;
  BackgroundImage: ImageField;
  Name: Field<string>;
  Photo: ImageField;
  Position: Field<string>;
}

export interface ArticleListItemProps {
  fields: Fields;
  name: string;
  url: string;
};

export interface ArticleListProps extends ComponentProps {
  fields: {
    items: ArticleListItemProps[];
  };
}

const props = Astro.props as ArticleListProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === 'Default' && <ArticleListDefault {...props} />}
  {variantName === 'ThreeColumn' && <ArticleListThreeColumn {...props} />}
  {variantName === 'Simplified' && <ArticleListSimplified {...props} />}
  {variantName === 'Grid' && <ArticleListGrid {...props} />}
</>