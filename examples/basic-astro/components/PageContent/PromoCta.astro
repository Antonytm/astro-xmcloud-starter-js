---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import PromoCtaDefault from "components/Variants/PromoCtaVariants/PromoCtaDefault.astro";
import PromoCtaWithPlaceholderColumn from "components/Variants/PromoCtaVariants/PromoCtaWithPlaceholderColumn.astro";
import PromoCtaWithBackgroundImage from "components/Variants/PromoCtaVariants/PromoCtaWithBackgroundImage.astro";

interface Fields {
  Eyebrow: Field<string>;
  Title: Field<string>;
  Subtitle: Field<string>;
  Text: RichTextField;
  Image: ImageField;
  Link: LinkField;
  Link2: LinkField;
}

export interface PromoCtaProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as PromoCtaProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <PromoCtaDefault {...props} />}
  {
    variantName === "WithPlaceholderColumn" && (
      <PromoCtaWithPlaceholderColumn {...props} />
    )
  }
  {
    variantName === "WithBackgroundImage" && (
      <PromoCtaWithBackgroundImage {...props} />
    )
  }
</>

<script>
  import setVisibility from "components/scripts/SetVisibility";
  
  const refs: NodeListOf<Element> = document.querySelectorAll(".promo-cta");
  setVisibility(refs);
</script>
