---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";

import AuthorListDefault from "components/Variants/AuthorListVariants/AuthorListDefault.astro";
import AuthorListSlider from "components/Variants/AuthorListVariants/AuthorListSlider.astro";
import AuthorListSimple from "components/Variants/AuthorListVariants/AuthorListSimple.astro";

interface Fields {
  Name: Field<string>;
  Photo: ImageField;
  Bio: RichTextField;
  Position: Field<string>;
}

export interface AuthorListItemProps {
  fields: Fields;
  name: string;
  url: string;
}

export interface AuthorListProps extends ComponentProps {
  fields: {
    items: AuthorListItemProps[];
  };
}

const props = Astro.props as AuthorListProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <AuthorListDefault {...props} />}
  {variantName === "Slider" && <AuthorListSlider {...props} />}
  {variantName === "Simple" && <AuthorListSimple {...props} />}
</>
