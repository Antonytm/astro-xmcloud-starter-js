---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import Testimonial from "components/NestedComponents/Testimonial.astro";

interface TestimonialFields {
  Rating: Field<string>;
  Content: Field<string>;
  AuthorName: Field<string>;
  AuthorPosition: Field<string>;
  AuthorImage: ImageField;
}

export interface TestimonialItemProps {
  fields: TestimonialFields;
};

export interface TestimonialsProps extends ComponentProps  {
  fields: {
    items: TestimonialItemProps[];
  };
};

const { params, fields } = Astro.props as TestimonialsProps;
const { styles, RenderingIdentifier: id } = params;
const testimonials = fields?.items;
---

<div
  class={`component testimonials ${styles?.trimEnd()}`}
  id={id}
>
  <div class="swiper">
    <div class="swiper-wrapper">
      {
        testimonials?.map((item) => (
          <div class="swiper-slide">
            <Testimonial {...item} />
          </div>
        ))
      }
    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script>
  import Swiper from "swiper";
  import { Autoplay, EffectCoverflow, Pagination } from "swiper/modules";

  export const swiperConfig = {
    modules: [Autoplay, EffectCoverflow, Pagination],
    autoplay: {
      delay: 3000,
      disableOnInteraction: true,
    },
    effect: "coverflow",
    coverflowEffect: {
      rotate: 0,
      stretch: 0,
      depth: 0,
      modifier: 1,
    },
    spaceBetween: 0,
    slidesPerView: 1,
    breakpoints: {
      992: {
        slidesPerView: 3,
      },
    },
    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },
    centeredSlides: true,
    loop: true,
    grabCursor: true,
  };

  new Swiper(".testimonials .swiper", swiperConfig);
</script>
