---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";
import CountUp from "components/NonSitecore/CountUp.astro";

interface Fields {
  Title1: Field<string>;
  Amount1: Field<string>;
  Currency1: Field<string>;
  Subtitle1: Field<string>;
  Value1: Field<string>;
  Amount2: Field<string>;
  Currency2: Field<string>;
  Subtitle2: Field<string>;
}

export interface ComparisonProps extends ComponentProps {
  fields: Fields;
}

const { fields, params } = Astro.props as ComparisonProps;
const { styles, RenderingIdentifier: id } = params;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
---

<div class={`component comparison ${styles?.trimEnd()}`} id={id}>
  <div class="title">
    <Text field={fields.Title1} />
  </div>
  <div class="d-flex justify-content-around">
    <div class="item">
      <div class="value">
        <span class="amount">
          {
            isPageEditing ? (
              <Text field={fields.Amount1} />
            ) : (
              <CountUp value={parseInt(fields.Amount1.value)} />
            )
          }
        </span>{" "}
        <span class="currency">
          <Text field={fields.Currency1} />
        </span>
      </div>
      <span class="subtitle">
        <Text field={fields.Subtitle1} />
      </span>
    </div>
    <div class="operator">
      <Text field={fields.Value1} />
    </div>
    <div class="item">
      <div class="value">
        <span class="amount">
          {
            isPageEditing ? (
              <Text field={fields.Amount2} />
            ) : (
              <CountUp value={parseInt(fields.Amount2.value)} />
            )
          }
        </span>{" "}
        <span class="currency">
          <Text field={fields.Currency2} />
        </span>
      </div>
      <span class="subtitle">
        <Text field={fields.Subtitle2} />
      </span>
    </div>
  </div>
</div>
