---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { ComponentProps } from "@/lib/component-props";

import QuoteDefault from "components/Variants/QuoteVariants/QuoteDefault.astro";
import QuoteSimple from "components/Variants/QuoteVariants/QuoteSimple.astro";

interface Fields {
  Quote: Field<string>;
  AuthorName: Field<string>;
  AuthorPosition: Field<string>;
  Image: ImageField;
}

export interface QuoteProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as QuoteProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <QuoteDefault {...props} />}
  {variantName === "Simple" && <QuoteSimple {...props} />}
</>
