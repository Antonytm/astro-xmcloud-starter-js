---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { ComponentProps } from "@/lib/component-props";

import ThreeColumnCtaDefault from "components/Variants/ThreeColumnCtaVariants/ThreeColumnCtaDefault.astro"
import ThreeColumnCtaWithIcons from "components/Variants/ThreeColumnCtaVariants/ThreeColumnCtaWithIcons.astro"
import ThreeColumnCtaWithIconsCompact from "components/Variants/ThreeColumnCtaVariants/ThreeColumnCtaWithIconsCompact.astro"

interface Fields {
  Text1: Field<string>;
  SubText1: Field<string>;
  Image1: ImageField;
  Link1: LinkField;
  Text2: Field<string>;
  SubText2: Field<string>;
  Image2: ImageField;
  Link2: LinkField;
  Text3: Field<string>;
  SubText3: Field<string>;
  Image3: ImageField;
  Link3: LinkField;
}

export interface ThreeColumnCtaProps extends ComponentProps {
  fields: Fields;
};

const props = Astro.props as ThreeColumnCtaProps;
const variantName = props.params.FieldNames ?? 'Default';
---

<>
  {variantName === 'Default' && <ThreeColumnCtaDefault {...props} />}
  {variantName === 'WithIcons' && <ThreeColumnCtaWithIcons {...props} />}
  {variantName === 'WithIconsCompact' && <ThreeColumnCtaWithIconsCompact {...props} />}
</>

<script>
  import setVisibility from "components/scripts/SetVisibility";

  const refs: NodeListOf<Element> = document.querySelectorAll(".three-column-cta .column");
  setVisibility(refs);
</script>