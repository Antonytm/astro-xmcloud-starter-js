---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import ArticleDetailsDefault from "components/Variants/ArticleDetailsVariants/ArticleDetailsDefault.astro";
import ArticleDetailsSimple from "components/Variants/ArticleDetailsVariants/ArticleDetailsSimple.astro";

interface Fields {
  Title: Field<string>;
  Excerpt: Field<string>;
  Content: RichTextField;
  Thumbnail: ImageField;
  BackgroundImage: ImageField;
  Name: Field<string>;
  Photo: ImageField;
  Position: Field<string>;
}

export interface ArticleDetailsProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as ArticleDetailsProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <ArticleDetailsDefault {...props} />}
  {variantName === "Simple" && <ArticleDetailsSimple {...props} />}
</>
