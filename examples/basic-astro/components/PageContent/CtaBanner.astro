---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import CtaBannerDefault from "components/Variants/CtaBannerVariants/CtaBannerDefault.astro";
import CtaBannerLargeImage from "components/Variants/CtaBannerVariants/CtaBannerLargeImage.astro";

interface Fields {
  Eyebrow: Field<string>;
  Title: Field<string>;
  Text: RichTextField;
  Link: LinkField;
  Image: ImageField;
  Icon: ImageField;
}

export interface CtaBannerProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as CtaBannerProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <CtaBannerDefault {...props} />}
  {variantName === "LargeImage" && <CtaBannerLargeImage {...props} />}
</>

<script>
  import setVisibility from "components/scripts/SetVisibility";

  const refs = document.querySelectorAll(".cta-banner img.fade-section");
  setVisibility(refs);
</script>
