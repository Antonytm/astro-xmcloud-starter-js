---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ComponentProps } from "@/lib/component-props";

import HeadingCtaDefault from "components/Variants/HeadingCtaVariants/HeadingCtaDefault.astro";
import HeadingCtaCompact from "components/Variants/HeadingCtaVariants/HeadingCtaCompact.astro";
import HeadingCtaPageHeading from "components/Variants/HeadingCtaVariants/HeadingCtaPageHeading.astro";
import HeadingCtaCentered from "components/Variants/HeadingCtaVariants/HeadingCtaCentered.astro";

interface Fields {
  Eyebrow: Field<string>;
  Heading: Field<string>;
  Text: Field<string>;
  Link: LinkField;
}

export interface HeadingCtaProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as HeadingCtaProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <HeadingCtaDefault {...props} />}
  {variantName === "Compact" && <HeadingCtaCompact {...props} />}
  {variantName === "PageHeading" && <HeadingCtaPageHeading {...props} />}
  {variantName === "Centered" && <HeadingCtaCentered {...props} />}
</>
