---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import Placeholder from "@astro-sitecore-jss/astro-content-sdk/src/components/Placeholder.astro";
import { useDictionary } from "@astro-sitecore-jss/astro-content-sdk/src/context";
import { ComponentProps } from "@/lib/component-props";

import {
  FacebookIcon,
  FacebookShareButton,
  LinkedinIcon,
  LinkedinShareButton,
  TwitterIcon,
  TwitterShareButton,
} from "react-share";

interface Fields {
  Title: Field<string>;
  Abstract: Field<string>;
  Category: Field<string>;
  Client: ImageField;
  Problem: RichTextField;
  Solution: RichTextField;
  Thumbnail: ImageField;
}

export interface ProjectDetailsProps extends ComponentProps {
  fields: Fields;
}

const { params, fields, rendering } = Astro.props as ProjectDetailsProps;
const { styles, RenderingIdentifier: id } = params;
const t = useDictionary();
const currentUrl = Astro.url.href;
---

<div class={`component project-details mt-4 mb-5 ${styles?.trimEnd()}`} id={id}>
  <div class="container container-wide">
    <div class="row gx-5">
      <div class="col-12 col-lg-6">
        <h1 class="display-1 fw-bold">
          <Text field={fields?.Title} />
        </h1>
        <p class="mb-0">
          <Text field={fields?.Abstract} />
        </p>
      </div>
      <div
        class="col-12 col-lg-6 d-flex flex-column align-items-end justify-content-end gap-3 mt-3"
      >
        <div>
          <span class="eyebrow-accent me-2">{t("Client") || "Client"}:</span>
          <AstroImage
            field={fields.Client}
            class="client-logo"
            height={40}
            width={100}
          />
        </div>
        <div>
          <span class="eyebrow-accent me-2">{t("Category") || "Category"}:</span
          >
          <Text field={fields.Category} />
        </div>
      </div>
    </div>
  </div>

  <div class="container container-widest-fluid">
    <AstroImage field={fields.Thumbnail} class="project-img img-fluid" />
  </div>
  <div class="container">
    <div class="article-content">
      <div class="row">
        <div class="col-12 col-lg-6 mx-auto">
          <div class="article-content-body rich-text mb-5">
            <RichText field={fields.Problem} />
          </div>
        </div>
        <div class="row">
          <Placeholder
            name="project-additional-content"
            rendering={rendering}
          />
        </div>
        <div class="col-12 col-lg-6 mx-auto">
          <div class="article-content-body rich-text my-5">
            <RichText field={fields.Solution} />
          </div>
        </div>
        <div
          class="col-12 d-flex gap-2 align-items-center justify-content-end mb-5"
        >
          <h6 class="eyebrow-accent mb-0 me-2">
            {t("Share on") || "Share on"}
          </h6>
          <FacebookShareButton client:load url={currentUrl}>
            <FacebookIcon
              round
              size={48}
              bgStyle={{ fill: "var(--bg-accent)" }}
            />
          </FacebookShareButton>
          <TwitterShareButton client:load url={currentUrl}>
            <TwitterIcon
              round
              size={48}
              bgStyle={{ fill: "var(--bg-accent)" }}
            />
          </TwitterShareButton>
          <LinkedinShareButton client:load url={currentUrl}>
            <LinkedinIcon
              round
              size={48}
              bgStyle={{ fill: "var(--bg-accent)" }}
            />
          </LinkedinShareButton>
        </div>
      </div>
    </div>
    <hr />
  </div>
</div>
