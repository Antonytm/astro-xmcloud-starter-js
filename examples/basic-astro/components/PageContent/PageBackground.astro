---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import Placeholder from "@astro-sitecore-jss/astro-content-sdk/src/components/Placeholder.astro";
import ParallaxBackgroundImage from "components/NonSitecore/ParallaxBackgroundImage.astro";
import { ComponentProps } from "@/lib/component-props";

interface Fields {
  Title: Field<string>;
  Content: RichTextField;
  BackgroundImage: ImageField;
}

export interface PageBackgroundProps extends ComponentProps {
  fields: Fields;
}

const { params, fields, rendering } = Astro.props as PageBackgroundProps;
const { styles, RenderingIdentifier: id } = params;
---

<div
  class={`component page-background col-12 ${styles?.trimEnd()}`}
  id={id ? id : undefined}
>
  <ParallaxBackgroundImage backgroundImage={fields.BackgroundImage} />

  <div class="container">
    <Placeholder name="page-navigation" rendering={rendering} />

    <h1 class="display-6 fw-bold">
      <Text field={fields.Title} />
    </h1>
    <div class="fs-2">
      <RichText field={fields.Content} />
    </div>
  </div>

  <div class="background-content-wrapper">
    <div class="background-content component-spaced container rounded-corners">
      <div class="p-3 p-sm-5">
        <div class="row">
          <Placeholder name="background-page-content" rendering={rendering} />
        </div>
      </div>
    </div>
  </div>
  <Placeholder name="page-content" rendering={rendering} />
</div>
