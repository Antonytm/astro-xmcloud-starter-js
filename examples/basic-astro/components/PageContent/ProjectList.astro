---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import ProjectListDefault from "components/Variants/ProjectListVariants/ProjectListDefault.astro";
import ProjectListMosaic from "components/Variants/ProjectListVariants/ProjectListMosaic.astro";

interface Fields {
  Title: Field<string>;
  Category: Field<string>;
  Abstract: Field<string>;
  Problem: RichTextField;
  Solution: RichTextField;
  Thumbnail: ImageField;
  Client: ImageField;
}

export interface ProjectListItemProps {
  fields: Fields;
  name: string;
  url: string;
}

export interface ProjectListProps extends ComponentProps {
  fields: {
    items: ProjectListItemProps[];
  };
}

const props = Astro.props as ProjectListProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <ProjectListDefault {...props} />}
  {variantName === "Mosaic" && <ProjectListMosaic {...props} />}
</>
