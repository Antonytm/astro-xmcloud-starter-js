---
import Link from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";

import { ParallaxBannerProps } from "components/PageContent/ParallaxBanner.astro";

const { fields } = Astro.props as ParallaxBannerProps;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
---

<div class="parallax-banner-content-inner">
  <h1 class="display-3 fw-bold text-center mb-3">
    <Text field={fields.Title} />
  </h1>
  <div class="fs-5 text-center">
    <RichText field={fields.Text} />

    {(isPageEditing || fields?.Link?.value?.href) && (
      <Link field={fields.Link} class="button button-main mt-3" />
    )}
  </div>
</div>