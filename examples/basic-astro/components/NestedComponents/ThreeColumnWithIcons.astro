---
import { ComponentParams, Field } from "@astro-sitecore-jss/astro-content-sdk";
import Link, {
  LinkField,
} from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";

export interface ColumnProps {
  image: ImageField;
  text: Field<string>;
  subText: Field<string>;
  link: LinkField;
  delay?: number;
  params?: ComponentParams;
};

const props = Astro.props as ColumnProps;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
---

<div
  class={`column col-sm-12 col-lg-4 ${!isPageEditing ? "fade-section" : ""} `}
  data-delay=`${props.delay}`
>
  <Link field={props.link} class="wrapper-link">
    <div class="content-wrapper">
      <div class="image-wrapper mb-5">
        <AstroImage field={props.image} height={32} />
      </div>
      <h2>
        <Text field={props.text} />
      </h2>
      <p>
        <Text field={props.subText} />
      </p>
    </div>
  </Link>
</div>
