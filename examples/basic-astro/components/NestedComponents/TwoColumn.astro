---
import { ComponentRendering, Field } from "@astro-sitecore-jss/astro-content-sdk";
import Link, { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";

import Placeholder from "@astro-sitecore-jss/astro-content-sdk/src/components/Placeholder.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";

export interface ColumnProps {
  image: ImageField;
  title: Field<string>;
  text: Field<string>;
  link: LinkField;
  placeholderName: string;
  delay?: number;
  rendering: ComponentRendering;
};

const props = Astro.props as ColumnProps;

const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;

const buttonStyle = props.rendering.params?.ButtonStyle
  ? `button-${props.rendering.params.ButtonStyle.toLowerCase()}`
  : "button-main";
---

<div
  class={`column col-sm-12 col-lg-6 ${!isPageEditing ? "fade-section" : ""}`}
  data-delay=`${props.delay}`
>
  <div class="content-wrapper">
    <AstroImage field={props.image} />
    {
      (isPageEditing || props.title?.value) && (
        <h2>
          <Text field={props.title} />
        </h2>
      )
    }
    {
      (isPageEditing || props.text?.value) && (
        <p>
          <Text field={props.text} />
        </p>
      )
    }
    {(isPageEditing || props.link?.value?.href) && <Link field={props.link} class=`button ${buttonStyle}` />}
    <Placeholder name={props.placeholderName} rendering={props.rendering} />
  </div>
</div>

<script>
  import setVisibility from "components/scripts/SetVisibility";

  const refs: NodeListOf<Element> = document.querySelectorAll(".two-column-cta .column");
  setVisibility(refs);
</script>