---
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { RichTextField } from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import { ComponentProps } from "@/lib/component-props";

import FooterDefault from "components/Variants/FooterVariants/FooterDefault.astro";
import FooterWithSocials from "components/Variants/FooterVariants/FooterWithSocials.astro";

interface Fields {
  Image1: ImageField;
  Title1: Field<string>;
  Text1: RichTextField;
  Title2: Field<string>;
  Text2: RichTextField;
  Title3: Field<string>;
  Text3: RichTextField;
  Title4: Field<string>;
  Text4: RichTextField;
  Copyright: Field<string>;
  Link1: LinkField;
  Link2: LinkField;
  SocialsTitle: Field<string>;
  SocialLink1: LinkField;
  SocialIcon1: ImageField;
  SocialLink2: LinkField;
  SocialIcon2: ImageField;
  SocialLink3: LinkField;
  SocialIcon3: ImageField;
}

export interface FooterProps extends ComponentProps {
  fields: Fields;
};

const props = Astro.props as FooterProps;
---

<>
  {props.params.FieldNames === 'Default' && <FooterDefault {...props} />}
  {props.params.FieldNames === 'WithSocials' && <FooterWithSocials {...props}/>}
</>