---
import { ComponentProps } from "@/lib/component-props";
import HeaderDefault from "components/Variants/HeaderVariants/HeaderDefault.astro";
import HeaderWithLogoImage from "components/Variants/HeaderVariants/HeaderWithLogoImage.astro";

const props = Astro.props as ComponentProps;
const variantName = props.params.FieldNames ?? "Default";

---

<>
  {variantName === 'Default' && <HeaderDefault {...props} />}
  {variantName === 'WithLogoImage' && <HeaderWithLogoImage {...props}/>}
</>