---
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import Link from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import {
  useDictionary,
  useSitecore,
} from "@astro-sitecore-jss/astro-content-sdk/src/context";
import { AuthorListProps } from "components/PageContent/AuthorList.astro";

const { fields, params } = Astro.props as AuthorListProps;
const { styles, RenderingIdentifier: id } = params;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;

const authors = fields?.items?.filter((item) => item.name !== "Data");
const t = useDictionary();
---

<div
  class={`component author-list author-list-simple ${styles?.trimEnd()}`}
  id={id}
>
  <div class="container">
    <div
      class="row gx-5 row-gap-5 justify-content-between justify-content-lg-start"
    >
      {
        authors?.map((author) => (
          <div class="col-sm-5 col-lg-3">
            <div>
              <AstroImage field={author.fields.Photo} />
            </div>
            <div>
              <h3 class="fs-4 mt-4 mb-1">
                <Text field={author.fields.Name} />
              </h3>
              <h4 class="position fw-normal mb-3">
                <Text field={author.fields.Position} />
              </h4>
              <div class={`bio ${isPageEditing ? "" : "clamped"}`}>
                <RichText field={author.fields.Bio} />
              </div>
              <Link field={{ href: author.url }} class="button button-simple">
                {t("Read more") || "Read more"}
              </Link>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
