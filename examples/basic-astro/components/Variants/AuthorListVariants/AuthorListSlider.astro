---
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import Link from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { AuthorListProps } from "components/PageContent/AuthorList.astro";

const { fields, params } = Astro.props as AuthorListProps;
const { styles, RenderingIdentifier: id } = params;
const authors = fields?.items?.filter((item) => item.name !== "Data");
---

<div
  class={`component author-list author-list-slider ${styles?.trimEnd()}`}
  id={id}
>
  <div class="container">
    <div class="swiper">
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-wrapper">
        {
          authors?.map((author) => (
            <div class="swiper-slide">
              <Link field={{ href: author.url }} class="wrapper-link">
                <AstroImage field={author.fields.Photo} />
                <h3 class="fs-4 mt-4">
                  <Text field={author.fields.Name} />
                </h3>
                <p>
                  <Text field={author.fields.Position} />
                </p>
              </Link>
            </div>
          ))
        }
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>
<script>
  import Swiper from "swiper";
  import { Navigation, Pagination } from "swiper/modules";

  export const swiperConfig = {
    modules: [Navigation, Pagination],
    spaceBetween: 30,
    slidesPerView: 1,
    breakpoints: {
      768: {
        slidesPerView: 2,
        slidesPerGroup: 2,
      },
      992: {
        slidesPerView: 4,
        slidesPerGroup: 4,
      },
    },
    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
    loop: true,
  };

  new Swiper(".author-list-slider .swiper", swiperConfig);
</script>
