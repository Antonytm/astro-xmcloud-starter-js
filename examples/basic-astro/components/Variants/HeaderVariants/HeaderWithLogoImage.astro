---
import Placeholder from "@astro-sitecore-jss/astro-content-sdk/src/components/Placeholder.astro";
import { ComponentProps } from "@/lib/component-props";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";

interface HeaderWithImageProps extends ComponentProps {
  fields: {
    LogoImage: ImageField;
  };
};

const { fields, rendering, params } = Astro.props as HeaderWithImageProps;
const { styles, RenderingIdentifier: id } = params;
---

<div class={`component header ${styles?.trimEnd()}`} id={id ? id : undefined}>
  <div class={`container container-${params?.ContainerWidth?.toLowerCase()}-fluid`}>
    <div class="row align-items-center">
      <div class="col-auto">
        <AstroImage field={fields.LogoImage} />
      </div>
      <div class="col">
        <Placeholder name="header-right" rendering={rendering} />
      </div>
    </div>
  </div>
</div>