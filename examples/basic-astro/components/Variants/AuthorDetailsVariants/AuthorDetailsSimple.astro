---
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import RichText from "@astro-sitecore-jss/astro-content-sdk/src/components/RichText.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { AuthorDetailsProps } from "components/PageContent/AuthorDetails.astro";

const { params, fields } = Astro.props as AuthorDetailsProps;
const { styles, RenderingIdentifier: id } = params;
---

<div
  class={`component author-details-simple col-12 ${styles?.trimEnd()}`}
  id={id}
>
  <div class="container container-wide">
    <div class="row g-5">
      <div class="text-col col-lg-8">
        <h6 class="eyebrow-accent">
          <Text field={fields.Position} />
        </h6>
        <h1 class="display-2 fw-bold">
          <Text field={fields.Name} />
        </h1>
        <div class="rich-content mb-4">
          <RichText field={fields.Bio} />
        </div>
      </div>
      <div class="img-col col-lg-4">
        <AstroImage field={fields.Photo} class="author-img img-fluid" />
      </div>
    </div>
  </div>
</div>
