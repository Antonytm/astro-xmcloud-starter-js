---
import Link from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";
import { HeadingCtaProps } from "components/PageContent/HeadingCta.astro";

const { fields, params } = Astro.props as HeadingCtaProps;
const { styles, RenderingIdentifier: id } = params;
const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
---

<div class={`component heading-cta compact ${styles?.trimEnd()}`} id={id}>
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="heading-content-wrapper">
          <h6 class="eyebrow-accent">
            <Text field={fields.Eyebrow} />
          </h6>
          <h2 class="display-6 fw-bold">
            <Text field={fields.Heading} />
          </h2>
          <p>
            <Text field={fields.Text} />
          </p>
        </div>
        {
          (isPageEditing || fields.Link?.value?.href) && (
            <Link field={fields.Link} class="button button-main" />
          )
        }
      </div>
    </div>
  </div>
</div>
