---
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import Text from "@astro-sitecore-jss/astro-content-sdk/src/components/Text.astro";
import { AuthorWidgetProps } from "components/PageContent/AuthorWidget.astro";

const { params, fields } = Astro.props as AuthorWidgetProps;
const { styles, RenderingIdentifier: id } = params;
---

<div class={`component author-widget ${styles?.trimEnd()}`} id={id}>
  <div class="author-card row g-0">
    <div class="col-auto">
      <AstroImage field={fields.Photo} class="author-img" />
    </div>
    <div class="col">
      <h6 class="author-name">
        <Text field={fields.Name} />
      </h6>
      <p class="author-position">
        <Text field={fields.Position} />
      </p>
    </div>
  </div>
</div>
