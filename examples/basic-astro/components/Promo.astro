---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import PromoDefault from "components/Variants/PromoVariants/PromoDefault.astro";
import PromoWithText from "components/Variants/PromoVariants/PromoWithText.astro";

interface Fields {
  PromoIcon: ImageField;
  PromoText: Field<string>;
  PromoLink: LinkField;
  PromoText2: Field<string>;
}

export interface PromoProps extends ComponentProps {
  fields: Fields;
}

const props = Astro.props as PromoProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <PromoDefault {...props} />}
  {variantName === "WithText" && <PromoWithText {...props} />}
</>
