---
import { ComponentProps } from "@/lib/component-props";
import { Field } from "@astro-sitecore-jss/astro-content-sdk";
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import { LinkField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Link.astro";
import ImageBanner from "components/Variants/ImageVariants/ImageBanner.astro";
import ImageDefault from "components/Variants/ImageVariants/ImageDefault.astro";

interface ImageFields {
  Image: ImageField;
  ImageCaption: Field<string>;
  TargetUrl: LinkField;
}

export interface ImageProps extends ComponentProps {
  fields: ImageFields;
}

const props = Astro.props as ImageProps;
const variantName = props.params.FieldNames ?? "Default";
---

<>
  {variantName === "Default" && <ImageDefault {...props} />}
  {variantName === "Banner" && <ImageBanner {...props} />}
</>
