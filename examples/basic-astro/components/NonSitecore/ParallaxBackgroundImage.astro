---
import { ImageField } from "@astro-sitecore-jss/astro-content-sdk/src/components/Image.astro";
import AstroImage from "@astro-sitecore-jss/astro-content-sdk/src/components/AstroImage.astro";
import { useSitecore } from "@astro-sitecore-jss/astro-content-sdk/src/context";

const { page } = useSitecore();
const isPageEditing = page.mode.isEditing;
const image = Astro.props.backgroundImage as ImageField;
const backgroundImage = image?.value?.src?.replaceAll(
  "http://renderingastro:3000",
  ""
);
---

{
  isPageEditing ? (
    <AstroImage field={backgroundImage} className="background-image" />
  ) : (
    <div class="parallax-background-image">
      <div
        class="parallax parallax-image"
        style={`background-image: url(${backgroundImage});`}
      />
    </div>
  )
}

<style>
  .parallax-background-image {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .parallax-image {
    background-position: center center;
    background-size: cover;
    position: absolute;
    will-change: transform;
  }
</style>

<script>
  import { useParallax, ParallaxElementOptions } from "lib/useParallax";

  document.addEventListener("DOMContentLoaded", function () {
    const backgroundImages = document.querySelectorAll(
      ".parallax-background-image"
    );

    const options: ParallaxElementOptions = {
      translateY: { from: -150, to: 150, units: "px" },
    };

    backgroundImages.forEach((backgroundImage) => {
      useParallax(backgroundImage as HTMLElement, options);
    });
  });
</script>
